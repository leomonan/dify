# Dify MCP工具项目配置文件
# 文件名: project.config
# 描述: Dify AI平台及MCP Bridge服务配置
# 创建日期: 2025年6月23日星期一 10:56:34
# 最后更新日期: 2025年6月23日星期一 10:56:34

# 项目基本信息
PROJECT_NAME="Dify MCP工具"
PROJECT_VERSION="0.1.0"
PROJECT_DESCRIPTION="Dify AI平台的本地部署与MCP协议桥接工具"
PROJECT_AUTHOR="Order602 Team"

# 依赖版本要求
PYTHON_MIN_VERSION="3.12"
NODE_MIN_VERSION="18.0.0"
DOCKER_MIN_VERSION="20.0.0"
PNPM_MIN_VERSION="8.0.0"

# 服务端口配置
DIFY_API_PORT="5001"
DIFY_WEB_PORT="3000"
MCP_BRIDGE_PORT="8080"

# 数据库端口配置
POSTGRES_PORT="5432"
REDIS_PORT="6379"
WEAVIATE_PORT="8085"
ELASTICSEARCH_PORT="9200"

# 目录路径配置
DIFY_DATA_DIR="mcp/data/dify_data"
LOGS_DIR="logs"
PIDS_DIR="pids"
DIFY_API_DIR="dify/api"
DIFY_WEB_DIR="dify/web"
MCP_BRIDGE_DIR="mcp-bridge"
DOCKER_VOLUMES_DIR="docker/volumes"

# 环境变量配置
DIFY_SECRET_KEY="your-secret-key-here"
DIFY_DATABASE_URL="postgresql://dify:dify@localhost:5432/dify"
DIFY_REDIS_URL="redis://localhost:6379/0"
DIFY_WEAVIATE_URL="http://localhost:8085"

# Docker配置
DOCKER_COMPOSE_FILE="docker/docker-compose.yaml"
DOCKER_NETWORK="dify-network"

# MCP Bridge配置
MCP_BRIDGE_HOST="localhost"
MCP_BRIDGE_LOG_LEVEL="INFO"

# Celery配置
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# 日志配置
LOG_LEVEL="INFO"
LOG_MAX_SIZE="100MB"
LOG_BACKUP_COUNT="5"

# 安全配置
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
API_RATE_LIMIT="100/hour"

# Git子模块配置
DIFY_REPO_URL="https://github.com/langgenius/dify.git"
DIFY_REPO_BRANCH="main"

# 启动超时配置（秒）
API_START_TIMEOUT="60"
WEB_START_TIMEOUT="120"
MCP_BRIDGE_START_TIMEOUT="30"
DOCKER_START_TIMEOUT="180"

# 健康检查配置
HEALTH_CHECK_INTERVAL="30"
HEALTH_CHECK_TIMEOUT="10"
HEALTH_CHECK_RETRIES="3" 